# Copiar este archivo a .env.local y completar los valores

# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"

# ── Ollama (embeddings) ───────────────────────────────────────────────────────
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=nomic-embed-text

# ── Whisper ───────────────────────────────────────────────────────────────────
# "medium" → faster-whisper descarga el modelo automáticamente la primera vez
# "./storage/models/medium" → si ya lo descargaste con: python workers/download_model.py
WHISPER_MODEL_PATH=medium

# ── FFmpeg (completar con la ruta real en este equipo) ────────────────────────
# Buscar con: Get-Command ffmpeg | Select-Object -ExpandProperty Source
FFMPEG_PATH=C:/ruta/a/ffmpeg.exe
FFPROBE_PATH=C:/ruta/a/ffprobe.exe

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_APP_NAME=LOGOS
NEXT_PUBLIC_APP_VERSION=0.1.0-poc
