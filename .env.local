# ── Air-gap ──────────────────────────────────────────────────────────────────
NEXT_TELEMETRY_DISABLED=1

# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"

# ── Ollama (embeddings) ───────────────────────────────────────────────────────
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=mxbai-embed-large

# ── Whisper ───────────────────────────────────────────────────────────────────
# "medium" → faster-whisper lo descarga y cachea automáticamente
# "./storage/models/medium" → después de correr: python workers/download_model.py
# WHISPER_MODEL_PATH=medium   ← volver acá si large-v3 no convence
WHISPER_MODEL_PATH=medium

# ── HuggingFace ───────────────────────────────────────────────────────────────
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# ── Paths opcionales (si no están en PATH del sistema) ────────────────────────
FFMPEG_PATH=C:/Users/acorrea/AppData/Local/Microsoft/WinGet/Packages/Gyan.FFmpeg_Microsoft.Winget.Source_8wekyb3d8bbwe/ffmpeg-8.1.1-full_build/bin/ffmpeg.exe
FFPROBE_PATH=C:/Users/acorrea/AppData/Local/Microsoft/WinGet/Packages/Gyan.FFmpeg_Microsoft.Winget.Source_8wekyb3d8bbwe/ffmpeg-8.1.1-full_build/bin/ffprobe.exe
PYTHON_PATH=C:/Users/acorrea/AppData/Local/Programs/Python/Python312/python.exe

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_PATH=./storage

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=LOGOS
NEXT_PUBLIC_APP_VERSION=0.1.0-poc
